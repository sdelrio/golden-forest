# npm Security Configuration
# Protects against lifecycle script injection attacks (e.g., TanStack May 2026 compromise)
#
# Usage: Place in project root as .npmrc or in ~/.npmrc for global protection

# Block ALL lifecycle scripts (preinstall, postinstall, install, prepare)
# This is the PRIMARY defense against script injection attacks
ignore-scripts=true

# Reject packages published less than 24 hours ago (1440 minutes)
# Gives security researchers time to detect and flag malicious releases
minimum-release-age=1440

# Enable automatic security auditing on install
audit=true

# Disable fund messages (reduces noise, not security-related)
fund=false
